# Environment Variables for Development
#
# IMPORTANT: This file is for development purposes only. Production deployments
# should use secure secrets management solutions such as:
# - AWS Secrets Manager
# - HashiCorp Vault
# - Azure Key Vault
# - Google Secret Manager
# - Kubernetes Secrets
# - Docker Secrets
#
# Copy this file to .env and fill in your actual values.

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=app

# Application Configuration
HTTP_PORT=8080

# Database Connection URL (optional - will be constructed from POSTGRES_* if not set)
# DATABASE_URL=postgres://postgres:your_password_here@postgres:5432/app

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Platform Authentication
PLATFORM_AUTH_MODE=open
PLATFORM_AUTH_TOKEN=dev-platform-token
