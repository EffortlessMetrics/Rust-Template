# Development environment secrets
# Copy to secret.env and fill in real values
# NEVER commit secret.env to version control
#
# Usage:
#   cp secret.env.example secret.env
#   # Edit secret.env with real values
#   kustomize build . | kubectl apply -f -

# Database credentials
DATABASE_URL=

# Application secrets
API_KEY=
JWT_SECRET=
REDIS_PASSWORD=

# Cloud provider credentials (optional for dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
