# Production environment secrets
# Copy to secret.env and fill in real values
# NEVER commit secret.env to version control
#
# CRITICAL: Production secrets MUST be injected via CI/CD or secret management system
# Prefer using a secrets manager (Vault, AWS Secrets Manager, etc.) over this file
#
# Usage:
#   cp secret.env.example secret.env
#   # Edit secret.env with real values
#   kustomize build . | kubectl apply -f -

# Database credentials
DATABASE_URL=
DATABASE_REPLICA_URL=

# Application secrets
API_KEY=
JWT_SECRET=
ENCRYPTION_KEY=

# Cache and session store
REDIS_PASSWORD=
REDIS_TLS_CERT=

# Cloud provider credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Third-party service tokens
STRIPE_API_TOKEN=
SENDGRID_API_KEY=
DATADOG_API_KEY=

# OAuth/OIDC
OAUTH_CLIENT_SECRET=
OIDC_CLIENT_SECRET=
