{
  "kind": "Deployment",
  "apiVersion": "apps/v1",
  "metadata": {
    "name": "test-app-api-key-exposed",
    "namespace": "default",
    "labels": {
      "app": "test-app",
      "version": "v1",
      "component": "api"
    }
  },
  "spec": {
    "replicas": 1,
    "selector": {
      "matchLabels": {
        "app": "test-app"
      }
    },
    "template": {
      "metadata": {
        "labels": {
          "app": "test-app",
          "version": "v1"
        }
      },
      "spec": {
        "securityContext": {
          "runAsNonRoot": true,
          "runAsUser": 1000
        },
        "containers": [
          {
            "name": "test-app",
            "image": "test-app:latest",
            "env": [
              {
                "name": "STRIPE_API_KEY",
                "value": "EXAMPLE_KEY_DO_NOT_USE_12345678"
              },
              {
                "name": "JWT_SECRET",
                "value": "super-secret-jwt-key-12345"
              }
            ],
            "resources": {
              "limits": {
                "cpu": "500m",
                "memory": "256Mi"
              },
              "requests": {
                "cpu": "100m",
                "memory": "128Mi"
              }
            }
          }
        ]
      }
    }
  }
}
