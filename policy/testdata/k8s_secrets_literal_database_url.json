{
  "kind": "Deployment",
  "apiVersion": "apps/v1",
  "metadata": {
    "name": "test-app-insecure",
    "namespace": "default",
    "labels": {
      "app": "test-app",
      "version": "v1",
      "component": "api"
    }
  },
  "spec": {
    "replicas": 1,
    "selector": {
      "matchLabels": {
        "app": "test-app"
      }
    },
    "template": {
      "metadata": {
        "labels": {
          "app": "test-app",
          "version": "v1"
        }
      },
      "spec": {
        "securityContext": {
          "runAsNonRoot": true,
          "runAsUser": 1000
        },
        "containers": [
          {
            "name": "test-app",
            "image": "test-app:latest",
            "env": [
              {
                "name": "DATABASE_URL",
                "value": "postgresql://user:password@db.example.com:5432/dbname"
              },
              {
                "name": "LOG_LEVEL",
                "value": "info"
              }
            ],
            "resources": {
              "limits": {
                "cpu": "500m",
                "memory": "256Mi"
              },
              "requests": {
                "cpu": "100m",
                "memory": "128Mi"
              }
            }
          }
        ]
      }
    }
  }
}
