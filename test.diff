    pub fn cache(&self) -> CachedSecurityHeaders {
        let mut headers = Vec::with_capacity(10);
        if let Some(csp) = &self.content_security_policy {
            if let Ok(v) = HeaderValue::from_str(csp) { headers.push(("content-security-policy", v)); }
        }
        if let Ok(v) = HeaderValue::from_str(&self.x_frame_options) { headers.push(("x-frame-options", v)); }
        if let Ok(v) = HeaderValue::from_str(&self.x_content_type_options) { headers.push(("x-content-type-options", v)); }
