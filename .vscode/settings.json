  "cSpell.enabled": true,
  "cSpell.ignorePaths": [
    "target/**",
    "node_modules/**",
    ".git/**",
    ".llm/**"
  ],

  // File associations
  "files.associations": {
    "*.feature": "cucumber"
  },

  // Editor configuration
  "editor.rulers": [100],
  "editor.formatOnSaveMode": "file",

  // Search configuration
  "search.exclude": {
    "**/target": true,
    "**/.git": true,
    "**/.llm": true,
    "**/node_modules": true
  },

  // Files configuration
  "files.watcherExclude": {
    "**/target/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true
  }
}
