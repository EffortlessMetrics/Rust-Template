    /// Cache configuration into a pre-parsed structure for zero-allocation access on the hot path
    pub fn cache(&self) -> CachedSecurityHeaders {
        CachedSecurityHeaders {
            content_security_policy: self.content_security_policy.as_deref().and_then(|s| HeaderValue::from_str(s).ok()),
            x_frame_options: HeaderValue::from_str(&self.x_frame_options).ok(),
            x_content_type_options: HeaderValue::from_str(&self.x_content_type_options).ok(),
            x_xss_protection: HeaderValue::from_str(&self.x_xss_protection).ok(),
            strict_transport_security: self.strict_transport_security.as_deref().and_then(|s| HeaderValue::from_str(s).ok()),
            referrer_policy: HeaderValue::from_str(&self.referrer_policy).ok(),
            permissions_policy: self.permissions_policy.as_deref().and_then(|s| HeaderValue::from_str(s).ok()),
            cross_origin_embedder_policy: self.cross_origin_embedder_policy.as_deref().and_then(|s| HeaderValue::from_str(s).ok()),
            cross_origin_opener_policy: self.cross_origin_opener_policy.as_deref().and_then(|s| HeaderValue::from_str(s).ok()),
            cross_origin_resource_policy: HeaderValue::from_str(&self.cross_origin_resource_policy).ok(),
            enabled: self.enabled,
        }
    }
}

